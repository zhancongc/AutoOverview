# Auth Kit 配置（Danmo Scholar 专属）
# 复制此文件为 .env.auth 并填写真实值

# ==================== JWT 配置 ====================
AUTH_JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars

# ==================== 邮件配置 ====================
AUTH_SMTP_HOST=your-smtp-host.com
AUTH_SMTP_PORT=587
AUTH_SMTP_USER=scholar@danmo.tech
AUTH_SMTP_PASSWORD=your-smtp-password
AUTH_SMTP_FROM_EMAIL=scholar@danmo.tech
AUTH_SMTP_FROM_NAME=Danmo Scholar

# ==================== 邮件模板配置（Danmo Scholar 品牌）====================
AUTH_EMAIL_APP_NAME=Danmo Scholar
AUTH_EMAIL_APP_URL=https://scholar.danmo.tech
AUTH_EMAIL_LOGO_EMOJI=📚
AUTH_EMAIL_CONTACT_EMAIL=scholar@danmo.tech
AUTH_EMAIL_PRIMARY_COLOR=#667eea
AUTH_EMAIL_SECONDARY_COLOR=#764ba2

# ==================== Redis 配置 ====================
AUTH_REDIS_HOST=localhost
AUTH_REDIS_PORT=6379
# AUTH_REDIS_PASSWORD=your-redis-password

# ==================== 验证码配置 ====================
AUTH_VERIFICATION_CODE_EXPIRE_MINUTES=10
AUTH_VERIFICATION_CODE_LENGTH=6

# ==================== 密码配置 ====================
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_PASSWORD_REQUIRE_UPPERCASE=true
AUTH_PASSWORD_REQUIRE_LOWERCASE=true
AUTH_PASSWORD_REQUIRE_DIGIT=true

# ==================== 数据库配置 ====================
# 使用 PostgreSQL（与主应用共用数据库）
AUTH_DATABASE_URL=postgresql://postgres:security@localhost/paper

# ==================== 支付配置 ====================
# 开发模式（true=模拟支付，不需要真实支付宝配置）
IS_DEV=true

# 支付宝配置（生产环境需要填写）
# 支持两种模式：公钥模式 或 证书模式（推荐证书模式）
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_APP_PRIVATE_KEY=your-alipay-app-private-key

# 模式1: 公钥模式（旧版，不推荐用于生产）
ALIPAY_PUBLIC_KEY=your-alipay-public-key

# 模式2: 证书模式（推荐，更安全）
# 证书文件默认放在 backend 目录下，也可以通过环境变量指定绝对路径
# ALIPAY_APP_CERT_PATH=/path/to/appCertPublicKey.crt
# ALIPAY_ALIPAY_CERT_PATH=/path/to/alipayCertPublicKey_RSA2.crt
# ALIPAY_ROOT_CERT_PATH=/path/to/alipayRootCert.crt

# ==================== 前后端地址 ====================
FRONTEND_URL=http://localhost:3006
BACKEND_URL=http://localhost:8006
EN_FRONTEND_URL=http://localhost:3006

# ==================== PayPal 配置（英文站）====================
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
PAYPAL_SANDBOX=true

# ==================== Paddle 配置（英文站备用）====================
PADDLE_API_KEY=your-paddle-api-key
PADDLE_VENDOR_ID=your-vendor-id
PADDLE_CLIENT_SIDE_TOKEN=your-client-side-token
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret
PADDLE_PRODUCT_ID=PROD_123456
PADDLE_SANDBOX=true
