# Auth Kit 环境配置示例
# 复制此文件为 .env 并填写真实值

# ==================== JWT 配置 ====================
AUTH_JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ==================== 邮件配置 ====================
AUTH_SMTP_HOST=smtp.gmail.com
AUTH_SMTP_PORT=587
AUTH_SMTP_USER=scholar@danmo.tech
AUTH_SMTP_PASSWORD=your-password-here
AUTH_SMTP_FROM_EMAIL=scholar@danmo.tech
AUTH_SMTP_FROM_NAME=Danmo Scholar

# 邮件模板配置（可选，用于自定义品牌信息）
AUTH_EMAIL_APP_NAME=Danmo Scholar
AUTH_EMAIL_APP_URL=https://scholar.danmo.tech
AUTH_EMAIL_APP_URL_EN=https://en-scholar.danmo.tech
AUTH_EMAIL_LOGO_EMOJI=📚
AUTH_EMAIL_CONTACT_EMAIL=service@danmo.tech
AUTH_EMAIL_CONTACT_EMAIL_EN=service@danmo.tech
AUTH_EMAIL_PRIMARY_COLOR=#667eea
AUTH_EMAIL_SECONDARY_COLOR=#764ba2

# 邮件服务说明：
# - Gmail: 需要启用"应用专用密码"
# - QQ邮箱: smtp.qq.com:587，需要使用授权码
# - 163邮箱: smtp.163.com:587，需要使用授权码

# ==================== Redis 配置 ====================
AUTH_REDIS_HOST=localhost
AUTH_REDIS_PORT=6379
AUTH_REDIS_DB=0
# AUTH_REDIS_PASSWORD=your-redis-password

# ==================== 验证码配置 ====================
AUTH_VERIFICATION_CODE_EXPIRE_MINUTES=10
AUTH_VERIFICATION_CODE_LENGTH=6

# ==================== 密码配置 ====================
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_PASSWORD_REQUIRE_UPPERCASE=true
AUTH_PASSWORD_REQUIRE_LOWERCASE=true
AUTH_PASSWORD_REQUIRE_DIGIT=true
AUTH_PASSWORD_REQUIRE_SPECIAL=false

# ==================== 数据库配置 ====================
AUTH_DATABASE_URL=postgresql://postgres:security@localhost/paper
